    private async Task AnalyzeUrl()
    {
        errorMessage = "";

        if (!IsValidUrl) 
        { 
            errorMessage = "Please enter a valid URL starting with http:// or https://"; 
            return; 
        }

       isBusy = true;
        StateHasChanged();

        try
        {
            preview = await MediaClient.AnalyzeUrlAsync(urlInput);
            if (preview != null)
            {
                showDownloadModal = true;
            }
            else
            {
                errorMessage = "Could not find video info. Check the link!";
            }
        }
       catch
        {
            errorMessage = "Server error.";
        }
        finally
        {
            isBusy = false;
            StateHasChanged();
        }
    
    }

    private async Task Download(string type)
    {
        showDownloadModal = false;
        isDownloading = true;
         showSuccess = false; // Reset
     
        //StateHasChanged();
  

        //var downloadUrl = $"/medias/download?url={Uri.EscapeDataString(urlInput)}&type={type}";
        //await JS.InvokeVoidAsync("location.assign", downloadUrl);

        var downloadUrl = MediaClient.BuildDownloadUrl(urlInput, type);
await JS.InvokeVoidAsync("location.assign", downloadUrl);

    await Task.Delay(7000); 
    showSuccess = true;
    await InvokeAsync(StateHasChanged);
        
     await Task.Delay(3000);
    isDownloading = false;
    showSuccess = false;
    //await LoadHistory();
    }

private string MediaUrl { get; set; } = string.Empty;

    // Handles clearing the field array
