                <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5
                 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 
                 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0z"/>
            </svg>
            Paste
        </button>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-outline-danger" @onclick="() => { urlInput = string.Empty; }">
            Clear
        </button>
        <button class="btn btn-secondary" @onclick="AnalyzeUrl" disabled="@isBusy">
            Analyze
        </button>
    </div>
</div>
        </div>


