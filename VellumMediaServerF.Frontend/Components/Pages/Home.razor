@if (showDownloadModal && preview != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow" style="border-radius: 15px;">
                <div class="modal-header border-0">
                    <h5 class="modal-title">Ready to Download?</h5>
                    <button type="button" class="btn-close" @onclick="() => showDownloadModal = false"></button>
                </div>
                <div class="modal-body text-center">
                    <h6>@preview.Title</h6>
                    <div class="d-grid gap-2 mt-3">
                        <button class="btn btn-success" @onclick='() => 
                            Download("video")'>Download MP4 Video</button>
                        <button class="btn btn-info text-white" @onclick='() => 
                            Download("mp3")'>Download MP3 Audio</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

