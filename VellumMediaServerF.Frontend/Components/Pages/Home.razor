private async Task PasteFromClipboard()
{
    try
    {
        // Call our JS function to get clipboard data safely
        var text = await JS.InvokeAsync<string>("clipboardExtensions.readText");
        
        if (!string.IsNullOrWhiteSpace(text))
        {
            urlInput = text;
            StateHasChanged(); // Force the UI input to update visually
        }
    }
    catch (Exception)
    {
        errorMessage = "Clipboard access was denied by your browser.";
    }
}
}